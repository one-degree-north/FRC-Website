---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';

const storyParagraphs = site.aboutStory.split('\n\n');
---

<Layout title="About" description="Get to know One Degree North, FRC Team 4817.">
	<section class="page-head intro-card">
		<p class="eyebrow">Get to know us</p>
		<h1>A team of ~30 students, one degree north of the equator</h1>
		{storyParagraphs.map((paragraph) => <p class="story">{paragraph}</p>)}
	</section>

	<section class="values-block">
		<h2>What we stand on</h2>
		<dl class="values">
			{
				site.values.map((value) => (
					<div class="value-tile">
						<dt>{value.name}</dt>
						<dd>{value.detail}</dd>
					</div>
				))
			}
		</dl>
	</section>

	<section class="milestones-card">
		<h2>Milestones</h2>
		<ol class="timeline">
			{
				site.milestones.map((milestone) => (
					<li>
						<span class="dot" aria-hidden="true" />
						<span class="year">{milestone.year}</span>
						<span class="event">{milestone.event}</span>
					</li>
				))
			}
		</ol>
		<p class="timeline-note">
			Full season-by-season results are on
			<a href="https://frc-events.firstinspires.org/team/4817">FIRST Inspires</a>.
		</p>
	</section>
</Layout>

<style>
	.intro-card {
		position: relative;
		padding: 24px;
		border: 1px solid var(--rule);
		border-radius: 8px;
		margin-top: 32px;
		margin-bottom: 12px;
	}

	.intro-card h1 {
		font-size: clamp(26px, 5vw, 34px);
		font-weight: 700;
		max-width: 26ch;
		margin: 0 0 20px;
		line-height: 1.15;
	}

	.story {
		max-width: 40rem;
		font-size: 15px;
		opacity: 0.85;
	}

	.values-block {
		margin-bottom: 36px;
		padding: 24px;
		background: var(--block);
		border-radius: 8px;
	}

	.values-block h2 {
		font-size: 20px;
		font-weight: 700;
		color: #fff;
		margin: 0 0 14px;
	}

	.values {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 14px;
		margin: 0;
	}

	@media (max-width: 40rem) {
		.values {
			grid-template-columns: 1fr;
		}
	}

	.value-tile {
		background: var(--accent);
		border-radius: 8px;
		padding: 16px;
	}

	.value-tile dt {
		font-family: var(--font-ui);
		font-weight: 700;
		font-size: 14px;
		color: #fff;
	}

	.value-tile dd {
		font-size: 13px;
		color: #fff;
		opacity: 0.85;
		margin: 4px 0 0;
	}

	.milestones-card {
		margin-bottom: 48px;
		padding: 24px;
		border: 1px solid var(--rule);
		border-radius: 8px;
	}

	.milestones-card h2 {
		font-size: 20px;
		font-weight: 700;
		margin: 0 0 18px;
	}

	.timeline {
		list-style: none;
		margin: 0;
		position: relative;
		padding-left: 24px;
		border-left: 2px solid var(--rule);
	}

	.timeline li {
		position: relative;
		padding-bottom: 26px;
	}

	.timeline li:last-child {
		padding-bottom: 0;
	}

	.dot {
		position: absolute;
		left: -31px;
		top: 2px;
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: var(--accent);
		border: 2px solid var(--surface);
	}

	.year {
		display: block;
		font-family: var(--font-ui);
		font-weight: 700;
		color: var(--accent-text);
		font-size: 13px;
		margin-bottom: 3px;
	}

	.event {
		font-size: 14px;
		opacity: 0.85;
	}

	.timeline-note {
		max-width: 40rem;
		font-size: 13px;
		color: var(--steel);
		margin: 20px 0 0;
	}

	.timeline-note a {
		color: var(--accent-text);
	}
</style>
