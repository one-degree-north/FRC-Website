---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
---

<Layout title="Outreach" description="Community and outreach programs of FRC Team 4817.">
	<section class="page-head intro-card">
		<span class="fig-label" aria-hidden="true">Fig. 03 / Outreach</span>
		<p class="eyebrow">Beyond the build season</p>
		<h1>Outreach</h1>
		<p class="note">
			This page is a placeholder — replace the cards below with the team's
			real outreach programs.
		</p>
	</section>

	<section class="programs">
		{
			site.outreachPrograms.map((program) => (
				<article class="program-card">
					<h3>{program.title}</h3>
					<p>{program.body}</p>
				</article>
			))
		}
	</section>
</Layout>

<style>
	.intro-card {
		padding: 24px;
		border: 1.5px solid var(--rule);
		border-radius: 18px;
		margin-top: 32px;
		margin-bottom: 12px;
	}

	.intro-card .fig-label {
		display: block;
		margin-bottom: 8px;
	}

	.intro-card h1 {
		font-size: clamp(26px, 5vw, 34px);
		font-weight: 700;
		margin: 0 0 8px;
	}

	.note {
		max-width: 40rem;
		font-size: 14px;
		color: var(--steel);
		margin: 0;
	}

	.programs {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 14px;
		margin-bottom: 48px;
	}

	@media (max-width: 44rem) {
		.programs {
			grid-template-columns: 1fr;
		}
	}

	.program-card {
		background: var(--block);
		border-radius: 14px;
		padding: 20px;
	}

	.program-card:hover {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.program-card h3 {
		font-size: 15px;
		font-weight: 700;
		color: #fff;
		margin: 0 0 8px;
	}

	.program-card p {
		font-size: 13px;
		color: var(--accent2);
		margin: 0;
	}
</style>
