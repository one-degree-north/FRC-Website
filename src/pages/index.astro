---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import { site } from '../data/site';

// Build the subteam pills from the lesson folders that actually exist, each
// linking to that subteam's first lesson (lowest slug — hence the 01-/02-
// naming convention). A renamed or deleted lesson can never leave a dead
// link here, and a new subteam folder gets a pill automatically.
const lessons = await getCollection('docs', (entry) =>
	entry.id.startsWith('lessons/'),
);
const firstLessonBySubteam = new Map<string, string>();
for (const lesson of lessons) {
	const [, subteam, ...rest] = lesson.id.split('/');
	if (!subteam || rest.length === 0) continue; // skip the lessons/ welcome page
	const current = firstLessonBySubteam.get(subteam);
	if (!current || lesson.id < current) firstLessonBySubteam.set(subteam, lesson.id);
}

const preferredOrder = ['programming', 'mechanical', 'electrical', 'cad', 'business'];
const labels: Record<string, string> = { cad: 'CAD' };
const subteams = [...firstLessonBySubteam.keys()]
	.sort(
		(a, b) =>
			(preferredOrder.indexOf(a) + 1 || 99) - (preferredOrder.indexOf(b) + 1 || 99) ||
			a.localeCompare(b),
	)
	.map((folder) => ({
		name: labels[folder] ?? folder.charAt(0).toUpperCase() + folder.slice(1),
		href: `/${firstLessonBySubteam.get(folder)}/`,
	}));

const record = [
	{ value: '2013', label: 'rookie year' },
	{ value: '14', label: 'seasons' },
	{ value: '22', label: 'events' },
	{ value: '7', label: 'awards' },
];
---

<Layout title="Home">
	<section class="hero">
		<div class="hero-circle" aria-hidden="true"></div>
		<div class="hero-inner">
			<span class="fig-label hero-fig" aria-hidden="true">Fig. 01 / Hero</span>
			<p class="eyebrow hero-eyebrow">
				FRC Team 4817 · Singapore · 1.3521°N 103.8198°E
			</p>
			<h1>One Degree North</h1>
			<p class="hero-intro">{site.homeIntro}</p>
			<div class="hero-actions">
				<a class="pill cta-primary" href="/about/">Get to know us</a>
				<a class="pill cta-secondary" href="/lessons/">Browse our lessons</a>
			</div>
		</div>
	</section>

	<div class="record-divider" aria-hidden="true">
		<span class="tick"></span>
		<span class="line"></span>
		<span class="label">TEAM RECORD</span>
		<span class="line"></span>
		<span class="tick"></span>
	</div>

	<section class="record-card" aria-label="Team record">
		<dl class="record">
			{
				record.map((stat) => (
					<div class="record-tile">
						<dd>{stat.value}</dd>
						<dt>{stat.label}</dt>
					</div>
				))
			}
			<div class="record-tile latest">
				<dt>latest</dt>
				<dd>2025 Hawaii Regional Winners</dd>
			</div>
		</dl>
	</section>

	<section class="subteams-card">
		<h2>Five subteams, one robot</h2>
		<p>
			Every member joins a subteam, and every subteam trains its next
			generation with its own lesson modules.
		</p>
		<div class="subteam-pills">
			{
				subteams.map((subteam) => (
					<a class="subteam-pill" href={subteam.href}>
						{subteam.name}
					</a>
				))
			}
		</div>
	</section>

	<section class="photos">
		<h2>Life on the team</h2>
		<PhotoGallery />
	</section>
</Layout>

<style>
	.hero {
		position: relative;
		overflow: hidden;
		padding: 56px 24px 40px;
		border-radius: 18px;
		margin-top: 32px;
		background: var(--accent);
	}

	.hero-circle {
		position: absolute;
		top: -40px;
		right: -60px;
		width: 220px;
		height: 220px;
		background: var(--accent2);
		opacity: 0.35;
		border-radius: 50%;
	}

	.hero-inner {
		position: relative;
	}

	.hero-fig {
		position: absolute;
		top: -8px;
		right: 0;
		color: var(--accent2);
	}

	@media (max-width: 40rem) {
		.hero-fig {
			display: none;
		}
	}

	.hero-eyebrow {
		color: var(--accent2);
		margin: 0 0 10px;
	}

	.hero h1 {
		font-size: clamp(38px, 7vw, 58px);
		font-weight: 700;
		letter-spacing: -0.01em;
		line-height: 1.05;
		margin: 0 0 14px;
		color: #fff;
	}

	.hero-intro {
		max-width: 36rem;
		font-size: 16px;
		color: #fff;
		opacity: 0.9;
		margin: 0 0 20px;
	}

	.hero-actions {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.cta-primary {
		background: var(--block);
		color: #fff;
	}

	.cta-primary:hover {
		background: var(--accent);
	}

	.cta-secondary {
		background: #fff;
		color: var(--block);
	}

	.cta-secondary:hover {
		background: var(--accent2);
	}

	.record-divider {
		display: flex;
		align-items: center;
		gap: 10px;
		margin: 28px 0 20px;
	}

	.record-divider .tick {
		width: 10px;
		height: 2px;
		background: var(--accent2);
	}

	.record-divider .line {
		flex: 1;
		border-top: 1.5px solid var(--rule);
	}

	.record-divider .label {
		font-family: var(--font-mono);
		font-size: 10.5px;
		font-weight: 600;
		letter-spacing: 0.08em;
		color: var(--accent-text);
	}

	.record-card {
		margin-bottom: 40px;
		padding: 20px;
		border: 1.5px solid var(--rule);
		border-radius: 18px;
	}

	.record {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 12px;
		margin: 0;
	}

	.record-tile {
		background: var(--block);
		border-radius: 14px;
		padding: 16px 12px;
		text-align: center;
	}

	.record-tile dd {
		margin: 0;
		font-size: 24px;
		font-weight: 700;
		color: #fff;
	}

	.record-tile dt {
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--accent2);
		margin-top: 2px;
	}

	.record-tile.latest {
		background: var(--accent2);
	}

	.record-tile.latest dt {
		color: var(--block);
		opacity: 0.7;
		margin: 0;
	}

	.record-tile.latest dd {
		font-size: 13px;
		font-weight: 700;
		color: var(--block);
		margin-top: 4px;
		line-height: 1.25;
	}

	@media (max-width: 44rem) {
		.record {
			grid-template-columns: repeat(2, 1fr);
		}

		.record-tile.latest {
			grid-column: 1 / -1;
		}
	}

	.subteams-card {
		margin-bottom: 40px;
		padding: 24px;
		border: 1.5px solid var(--rule);
		border-radius: 18px;
	}

	.subteams-card h2 {
		font-size: 24px;
		font-weight: 700;
		margin: 0 0 8px;
	}

	.subteams-card p {
		opacity: 0.75;
		margin: 0 0 16px;
		max-width: 38rem;
	}

	.subteam-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.subteam-pill {
		display: inline-block;
		padding: 10px 20px;
		border-radius: 24px;
		background: var(--block);
		color: #fff;
		text-decoration: none;
		font-weight: 700;
		font-size: 13px;
		transition: background 0.15s;
	}

	.subteam-pill:hover {
		background: var(--accent);
	}

	.photos {
		margin-bottom: 48px;
	}

	.photos h2 {
		font-size: 24px;
		font-weight: 700;
		margin: 0 0 16px;
	}
</style>
