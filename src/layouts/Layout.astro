---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/bricolage-grotesque';
import { site } from '../data/site';

interface Props {
	title: string;
	description?: string;
}

const { title, description = site.tagline } = Astro.props;

const pageTitle = `${title} · One Degree North · FRC 4817`;
// Astro.site is set in astro.config.mjs; fall back gracefully for dev/preview.
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const ogImage = new URL('/og.png', Astro.site ?? Astro.url);

const nav = [
	{ label: 'Home', href: '/' },
	{ label: 'About', href: '/about/' },
	{ label: 'Outreach', href: '/outreach/' },
	{ label: 'Lessons', href: '/lessons/' },
];
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="canonical" href={canonical} />
		<meta name="description" content={description} />
		<title>{pageTitle}</title>

		<meta property="og:site_name" content="One Degree North — FRC 4817" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<script is:inline>
			// Apply the theme before first paint to avoid a flash.
			// Dark is the default; only an explicit "light" choice opts out.
			try {
				if (localStorage.getItem('odn-theme') !== 'light') {
					document.documentElement.dataset.theme = 'dark';
				}
			} catch (e) {
				document.documentElement.dataset.theme = 'dark';
			}
		</script>
	</head>
	<body>
		<header class="site-header">
			<a class="wordmark" href="/">
				<span class="wordmark-badge">1°N</span>
				<span class="wordmark-text">One Degree North<small>FRC Team 4817</small></span>
			</a>
			<nav aria-label="Main">
				{
					nav.map((item) => (
						<a
							href={item.href}
							class:list={{ active: currentPath === item.href }}
							aria-current={currentPath === item.href ? 'page' : undefined}
						>
							{item.label}
						</a>
					))
				}
				<button id="theme-toggle" type="button" aria-live="polite">Light ☀</button>
			</nav>
		</header>

		<div class="page">
			<main>
				<slot />
			</main>

			<footer class="site-footer">
				<div class="footer-top">
					<p class="footer-id">
						<strong>One Degree North</strong> — FRC Team 4817, Singapore American School<br />
						<a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
					</p>
					<span class="footer-coord">1.3521° N / 103.8198° E</span>
				</div>
				<div class="footer-bottom">
					<span class="footer-follow">Follow the team</span>
					<div class="footer-social">
						{/* Add socials with real URLs when ready, e.g.
						    <a href="https://instagram.com/...">Instagram</a> */}
						<a href="https://frc-events.firstinspires.org/team/4817">FIRST Inspires</a>
					</div>
				</div>
			</footer>
		</div>

		<script>
			import '../scripts/scroll-animations.js';
		</script>
		<script is:inline>
			(() => {
				const button = document.getElementById('theme-toggle');
				const root = document.documentElement;
				const setLabel = () => {
					button.textContent = root.dataset.theme === 'dark' ? 'Dark ☾' : 'Light ☀';
				};
				setLabel();
				button.addEventListener('click', () => {
					const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
					if (next === 'dark') root.dataset.theme = 'dark';
					else delete root.dataset.theme;
					try {
						localStorage.setItem('odn-theme', next);
					} catch (e) {}
					setLabel();
				});
			})();
		</script>
	</body>
</html>

<style is:global>
	/* Design tokens — light mode (see design_handoff_burgundy_redesign/README.md) */
	:root {
		--paper: #fff8f4;
		--ink: #1a1210;
		--steel: #6b5d59;
		--accent: #8c1f3f;
		--accent-text: #8c1f3f;
		--accent2: #f2b632;
		--surface: #ffffff;
		--rule: #ecdfd9;
		--block: #1a1210;
		--grid: rgba(140, 31, 63, 0.06);
		--font-body: 'Space Grotesk Variable', sans-serif;
		--font-mono: 'JetBrains Mono Variable', ui-monospace, monospace;
		--font-badge: 'Bricolage Grotesque Variable', sans-serif;
	}

	:root[data-theme='dark'] {
		--paper: #150b0d;
		--ink: #f5ece7;
		--steel: #c9a8ad;
		--accent: #7a2331;
		--accent-text: #e08a97;
		--accent2: #f2b632;
		--surface: #241016;
		--rule: #3a1e24;
		--block: #2a1015;
		--grid: rgba(242, 182, 50, 0.08);
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		background: var(--paper);
		color: var(--ink);
		font-family: var(--font-body);
		font-size: 16px;
		line-height: 1.55;
	}

	/* Blueprint grid paper behind the whole content column; fills the
	   viewport so the footer never floats on short pages. */
	.page {
		width: 100%;
		max-width: 960px;
		margin: 0 auto;
		flex: 1;
		display: flex;
		flex-direction: column;
		background-image: linear-gradient(var(--grid) 1px, transparent 1px),
			linear-gradient(90deg, var(--grid) 1px, transparent 1px);
		background-size: 28px 28px;
	}

	main {
		padding: 0 32px;
		flex: 1;
	}

	h1,
	h2,
	h3 {
		text-wrap: balance;
	}

	a {
		color: inherit;
	}

	/* Mono-caps eyebrow used at the top of major sections. */
	.eyebrow {
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent-text);
		margin: 0 0 8px;
	}

	/* Blueprint-style "Fig. 0N / Section" annotation, one per major section. */
	.fig-label {
		font-family: var(--font-mono);
		font-size: 10.5px;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--accent-text);
	}

	.pill {
		display: inline-block;
		padding: 12px 22px;
		border-radius: 24px;
		font-weight: 700;
		font-size: 14px;
		text-decoration: none;
		transition: background 0.15s, color 0.15s;
	}

	:focus-visible {
		outline: 2px solid var(--accent-text);
		outline-offset: 2px;
	}
</style>

<style>
	.site-header {
		width: 100%;
		max-width: 960px;
		margin: 0 auto;
		padding: 20px 32px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		flex-wrap: wrap;
		background: var(--surface);
		border-bottom: 1px solid var(--rule);
	}

	.wordmark {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
	}

	.wordmark-badge {
		font-family: var(--font-badge);
		font-weight: 800;
		font-size: 15px;
		color: #fff;
		background: var(--accent);
		padding: 6px 10px;
		border-radius: 8px;
		transform: rotate(-3deg);
		display: inline-block;
	}

	.wordmark-text {
		font-weight: 700;
		font-size: 15px;
		line-height: 1.2;
	}

	.wordmark-text small {
		display: block;
		font-family: var(--font-mono);
		font-weight: 400;
		font-size: 10px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--steel);
	}

	nav {
		display: flex;
		gap: 8px;
		align-items: center;
		flex-wrap: wrap;
	}

	nav a {
		font-weight: 700;
		font-size: 13px;
		text-decoration: none;
		color: var(--ink);
		padding: 8px 16px;
		border-radius: 20px;
		transition: background 0.15s;
	}

	nav a:hover {
		background: var(--paper);
	}

	nav a.active {
		color: #fff;
		background: var(--block);
	}

	#theme-toggle {
		font-family: var(--font-mono);
		font-weight: 600;
		font-size: 11px;
		background: var(--surface);
		border: 1.5px solid var(--rule);
		color: var(--ink);
		padding: 7px 14px;
		border-radius: 20px;
		cursor: pointer;
		transition: border-color 0.15s, color 0.15s;
	}

	#theme-toggle:hover {
		border-color: var(--accent);
		color: var(--accent-text);
	}

	.site-footer {
		padding: 32px;
		background: var(--block);
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.footer-top {
		display: flex;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 16px;
	}

	.footer-id {
		margin: 0;
		font-size: 12px;
		color: #fff;
		opacity: 0.85;
	}

	.footer-id a {
		color: #fff;
	}

	.footer-coord {
		font-family: var(--font-mono);
		font-size: 10.5px;
		letter-spacing: 0.08em;
		color: var(--accent2);
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 12px;
		padding-top: 18px;
		border-top: 1px solid rgba(255, 255, 255, 0.15);
	}

	.footer-follow {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--steel);
	}

	.footer-social {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
	}

	.footer-social a {
		font-size: 12px;
		font-weight: 600;
		color: #fff;
		border: 1.5px solid var(--accent2);
		border-radius: 20px;
		padding: 6px 14px;
		text-decoration: none;
		transition: background 0.15s, color 0.15s;
	}

	.footer-social a:hover {
		background: var(--accent2);
		color: var(--block);
	}
</style>
