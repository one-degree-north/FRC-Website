---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Any image dropped into src/assets/gallery/ shows up here automatically.
const images = Object.values(
	import.meta.glob<{ default: ImageMetadata }>(
		'../assets/gallery/*.{jpg,jpeg,png,webp}',
		{ eager: true },
	),
).map((mod) => mod.default);
---

{
	images.length > 0 ? (
		<div class="gallery">
			{images.map((image) => (
				<Image src={image} alt="One Degree North team photo" width={640} />
			))}
		</div>
	) : (
		<div class="gallery-empty">
			<p>
				<strong>Photos go here.</strong> Drop image files into
				<code>src/assets/gallery/</code> and they'll appear automatically.
			</p>
		</div>
	)
}

<style>
	.gallery {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
		gap: 1rem;
	}

	.gallery :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 14px;
		display: block;
	}

	.gallery-empty {
		border: 1.5px dashed var(--accent2);
		border-radius: 16px;
		padding: 38px 20px;
		text-align: center;
		color: var(--steel);
		font-family: var(--font-mono);
		font-size: 12px;
	}

	.gallery-empty code {
		font-size: 1em;
	}
</style>
