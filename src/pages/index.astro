---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import { site } from '../data/site';

// Link each subteam chip to that subteam's first lesson (lowest slug — hence
// the 01-/02- naming convention), discovered from the lesson folders that
// actually exist. A renamed or deleted lesson can never leave a dead link
// here. Subteams with no lessons yet still render as plain (unlinked) chips.
const lessons = await getCollection('docs', (entry) =>
	entry.id.startsWith('lessons/'),
);
const firstLessonBySubteam = new Map<string, string>();
for (const lesson of lessons) {
	const [, subteam, ...rest] = lesson.id.split('/');
	if (!subteam || rest.length === 0) continue; // skip the lessons/ welcome page
	const current = firstLessonBySubteam.get(subteam);
	if (!current || lesson.id < current) firstLessonBySubteam.set(subteam, lesson.id);
}

const subteams = site.subteams.map((subteam) => {
	const lessonId = firstLessonBySubteam.get(subteam.name.toLowerCase());
	return { ...subteam, href: lessonId ? `/${lessonId}/` : undefined };
});

// Game-launch countdown copy comes from the CMS. The pretty date shown in
// the label is formatted from the ISO date so editors only set it once; the
// live day count is computed client-side (see the script below).
const launchDate = new Date(`${site.gameLaunch.date}T00:00:00`);
const launchPretty = launchDate.toLocaleDateString('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
});

// The count-up animation runs client-side; `animate: false` numbers (the
// rookie year) render as-is instead of counting from zero.
const record = [
	{ value: 2013, label: 'rookie year', animate: false },
	{ value: 14, label: 'seasons', animate: true },
	{ value: 22, label: 'events', animate: true },
	{ value: 7, label: 'awards', animate: true },
];
---

<Layout title="Home">
	<section class="hero">
		<div class="hero-circle" aria-hidden="true"></div>
		<div class="hero-inner">
			<p class="eyebrow hero-eyebrow">FRC Team 4817 · Singapore</p>
			<h1>One Degree North</h1>
			<p class="hero-intro">{site.homeIntro}</p>
			<div class="hero-actions">
				<a class="btn btn-solid" href="/about/">Get to know us</a>
				<a class="btn btn-outline" href="/lessons/">Browse our lessons</a>
			</div>
		</div>
	</section>

	<div class="countdown" data-kickoff={site.gameLaunch.date}>
		{site.gameLaunch.label} ({launchPretty}) in <span class="countdown-n">…</span>
	</div>

	<section class="record-section" aria-label="Team record">
		<h2 class="section-label">Team record</h2>
		<dl class="record">
			{
				record.map((stat) => (
					<div class="record-tile">
						<dd
							data-count={stat.animate ? String(stat.value) : undefined}
						>
							{stat.value}
						</dd>
						<dt>{stat.label}</dt>
					</div>
				))
			}
		</dl>
		<div class="ribbons">
			{
				site.awards.map((award) => (
					<div class="ribbon">
						<span class="ribbon-notch" aria-hidden="true" />
						<span class="ribbon-text">
							{award.icon ?? '🏅'} {award.year} {award.title}
						</span>
					</div>
				))
			}
		</div>
	</section>

	<section class="subteams-section">
		<h2>Five subteams, one robot</h2>
		<p class="subteams-lead">Hover a subteam to see what they actually do.</p>
		<div class="subteam-chips">
			{
				subteams.map((subteam) => {
					const Tag = subteam.href ? 'a' : 'div';
					return (
						<Tag class="chip" href={subteam.href}>
							<span>{subteam.name}</span>
							<span class="chip-tip">{subteam.blurb}</span>
						</Tag>
					);
				})
			}
		</div>
	</section>

	<section class="photos">
		<h2>Life on the team</h2>
		<PhotoGallery />
	</section>
</Layout>

<style>
	.hero {
		position: relative;
		overflow: hidden;
		padding: 56px 24px 44px;
		border-radius: 8px;
		margin-top: 32px;
		background: var(--accent);
	}

	.hero-circle {
		position: absolute;
		top: -40px;
		right: -60px;
		width: 220px;
		height: 220px;
		background: var(--accent2);
		opacity: 0.35;
		border-radius: 50%;
	}

	.hero-inner {
		position: relative;
	}

	.hero-eyebrow {
		color: var(--accent2);
		margin: 0 0 10px;
	}

	.hero h1 {
		font-size: clamp(38px, 7vw, 52px);
		font-weight: 800;
		letter-spacing: -0.01em;
		line-height: 1.06;
		margin: 0 0 14px;
		color: #fff;
	}

	.hero-intro {
		max-width: 36rem;
		font-size: 16px;
		color: #fff;
		opacity: 0.9;
		margin: 0 0 22px;
	}

	.hero-actions {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
		font-family: var(--font-ui);
	}

	.btn {
		display: inline-block;
		padding: 11px 20px;
		font-weight: 700;
		font-size: 14px;
		text-decoration: none;
		border-radius: 6px;
		transition: transform 0.15s, border-color 0.15s;
	}

	.btn:hover {
		transform: translateY(-2px);
	}

	.btn-solid {
		background: var(--block);
		color: #fff;
	}

	.btn-outline {
		border: 1.5px solid rgba(255, 255, 255, 0.5);
		color: #fff;
	}

	.btn-outline:hover {
		border-color: #fff;
	}

	.countdown {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		margin: 20px 0;
		padding: 10px;
		background: var(--surface);
		border: 1px solid var(--rule);
		border-radius: 6px;
		font-family: var(--font-ui);
		font-size: 13px;
		font-weight: 600;
		color: var(--ink);
	}

	.countdown-n {
		color: var(--accent-text);
		font-weight: 800;
		font-size: 15px;
	}

	.record-section {
		margin-bottom: 40px;
	}

	.section-label {
		font-family: var(--font-ui);
		font-size: 15px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--steel);
		margin: 0 0 14px;
	}

	.record {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0;
		margin: 0;
		border: 1px solid var(--rule);
		border-radius: 8px;
		overflow: hidden;
	}

	.record-tile {
		padding: 18px 14px;
		text-align: center;
		border-right: 1px solid var(--rule);
	}

	.record-tile:last-child {
		border-right: none;
	}

	.record-tile dd {
		margin: 0;
		font-family: var(--font-ui);
		font-size: 26px;
		font-weight: 800;
		color: var(--ink);
	}

	.record-tile dt {
		font-family: var(--font-ui);
		font-size: 11px;
		color: var(--steel);
		margin-top: 2px;
	}

	@media (max-width: 40rem) {
		.record {
			grid-template-columns: repeat(2, 1fr);
		}

		.record-tile:nth-child(2) {
			border-right: none;
		}

		.record-tile:nth-child(1),
		.record-tile:nth-child(2) {
			border-bottom: 1px solid var(--rule);
		}
	}

	.ribbons {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 12px;
	}

	.ribbon {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 14px 8px 10px;
		background: var(--accent2);
		border-radius: 0 6px 6px 0;
		position: relative;
	}

	.ribbon-notch {
		position: absolute;
		left: -1px;
		top: 0;
		bottom: 0;
		width: 5px;
		background: var(--accent);
		clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%, 50% 50%);
	}

	.ribbon-text {
		font-family: var(--font-ui);
		font-size: 12px;
		font-weight: 800;
		color: var(--block);
		margin-left: 8px;
	}

	.subteams-section {
		position: relative;
		margin-bottom: 40px;
	}

	/* While a chip is hovered, lift the whole section above the sections that
	   follow it — the gallery below gets its own stacking context from the
	   scroll-reveal transform, which would otherwise paint over the tooltip. */
	.subteams-section:has(.chip:hover) {
		z-index: 5;
	}

	.subteams-section h2 {
		font-size: 22px;
		font-weight: 700;
		margin: 0 0 8px;
	}

	.subteams-lead {
		opacity: 0.75;
		margin: 0 0 16px;
		max-width: 38rem;
	}

	.subteam-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		font-family: var(--font-ui);
	}

	.chip {
		position: relative;
		padding: 8px 16px;
		border-radius: 6px;
		border: 1.5px solid var(--rule);
		color: var(--ink);
		font-weight: 600;
		font-size: 13px;
		text-decoration: none;
		cursor: default;
		z-index: 1;
		transition: background 0.15s, color 0.15s, border-color 0.15s;
	}

	a.chip {
		cursor: pointer;
	}

	.chip:hover {
		background: var(--block);
		color: #fff;
		border-color: var(--block);
	}

	.chip-tip {
		position: absolute;
		top: calc(100% + 6px);
		left: 0;
		width: 200px;
		padding: 10px 12px;
		background: var(--block);
		color: #fff;
		font-weight: 400;
		font-size: 12px;
		line-height: 1.4;
		border-radius: 6px;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.15s;
		z-index: 2;
	}

	.chip:hover .chip-tip,
	.chip:focus-visible .chip-tip {
		opacity: 1;
	}

	.photos {
		margin-bottom: 48px;
	}

	.photos h2 {
		font-size: 22px;
		font-weight: 700;
		margin: 0 0 16px;
	}
</style>

<script is:inline>
	(() => {
		// Live countdown to the FRC 2027 (BIOCORE) kickoff — computed from the
		// visitor's current date so it's never stale.
		const el = document.querySelector('.countdown');
		if (el) {
			const kickoff = new Date(el.dataset.kickoff + 'T00:00:00');
			const days = Math.max(
				0,
				Math.ceil((kickoff - new Date()) / (1000 * 60 * 60 * 24)),
			);
			el.querySelector('.countdown-n').textContent =
				days + (days === 1 ? ' day' : ' days');
		}

		// Count-up: animate marked stats from 0 to their value on mount
		// (ease-out cubic, ~900ms). Skipped when the visitor prefers reduced
		// motion — the final number is already in the markup.
		const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (!reduce) {
			const ease = (x) => 1 - Math.pow(1 - x, 3);
			for (const node of document.querySelectorAll('[data-count]')) {
				const target = Number(node.dataset.count);
				const start = performance.now();
				const step = (now) => {
					const t = Math.min(1, (now - start) / 900);
					node.textContent = String(Math.round(target * ease(t)));
					if (t < 1) requestAnimationFrame(step);
				};
				requestAnimationFrame(step);
			}
		}
	})();
</script>
