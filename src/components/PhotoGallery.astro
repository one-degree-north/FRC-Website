---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import gallery from '../data/gallery.json';

// Photos are managed in the CMS ("Photo gallery" singleton), which saves the
// image files into src/assets/gallery/ and records them in gallery.json. We
// resolve each saved path to its optimized asset via import.meta.glob. The
// glob is recursive so it works regardless of how the CMS lays out the files.
const files = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/gallery/**/*.{jpg,jpeg,png,webp}',
	{ eager: true },
);

const photos = gallery.photos
	.map((photo) => ({ mod: files[photo.image], alt: photo.alt ?? '' }))
	.filter((photo): photo is { mod: { default: ImageMetadata }; alt: string } =>
		Boolean(photo.mod),
	);
---

{
	photos.length > 0 ? (
		<div class="gallery">
			{photos.map(({ mod, alt }) => (
				<figure class="gallery-item">
					<Image src={mod.default} alt={alt} width={640} />
					{alt && <figcaption>{alt}</figcaption>}
				</figure>
			))}
		</div>
	) : (
		// Photos are added through the CMS "Photo gallery" — see README.
		<div class="gallery-empty">
			<p>Team photos coming soon.</p>
		</div>
	)
}

<style>
	.gallery {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
		gap: 1rem;
	}

	.gallery-item {
		margin: 0;
		position: relative;
		overflow: hidden;
		border-radius: 14px;
	}

	.gallery-item :global(img) {
		width: 100%;
		aspect-ratio: 3 / 2;
		object-fit: cover;
		display: block;
	}

	/* Caption slides up over the bottom of the photo on hover/focus. */
	.gallery-item figcaption {
		position: absolute;
		inset: auto 0 0 0;
		padding: 2.25rem 0.9rem 0.85rem;
		color: #fff;
		font-size: 0.9rem;
		line-height: 1.35;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.78), transparent);
		transform: translateY(100%);
		transition: transform 0.28s ease;
	}

	.gallery-item:hover figcaption,
	.gallery-item:focus-within figcaption {
		transform: translateY(0);
	}

	@media (prefers-reduced-motion: reduce) {
		.gallery-item figcaption {
			transition: none;
		}
	}

	.gallery-empty {
		border: 1.5px dashed var(--accent2);
		border-radius: 16px;
		padding: 38px 20px;
		text-align: center;
		color: var(--steel);
		font-family: var(--font-mono);
		font-size: 12px;
	}
</style>
